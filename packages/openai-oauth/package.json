{
	"name": "llm-compatible-api",
	"version": "1.0.1",
	"description": "Bridge upstream LLM APIs into an OpenAI-compatible local endpoint.",
	"type": "module",
	"bin": {
		"llm-compatible-api": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup src/index.ts src/cli.ts --format esm --dts --outDir dist --clean",
		"dev": "tsx src/cli.ts",
		"prepublishOnly": "pnpm run build",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:live": "LIVE_CODEX_E2E=1 vitest run test/live.e2e.test.ts"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "3.0.75",
		"@ai-sdk/provider": "3.0.10",
		"ai": "6.0.116",
		"yargs": "^17.7.2"
	},
	"devDependencies": {
		"@ai-sdk/openai": "3.0.41",
		"@types/node": "20.17.24",
		"@types/yargs": "^17.0.33",
		"openai-oauth-core": "workspace:*",
		"openai-oauth-provider": "workspace:*",
		"typescript": "latest",
		"vitest": "latest",
		"zod": "^3.25.76"
	},
	"author": "EvanZhouDev",
	"license": "AGPL-3.0-only",
	"bugs": {
		"url": "https://github.com/postor/llm-compatible-api/issues"
	},
	"homepage": "https://github.com/postor/llm-compatible-api#readme"
}
