# Copy this file to .env only if you want environment variables to override
# the saved Docker Compose profile created by `docker compose run --rm llm-compatible-api init`.
#
# Required when serving without a saved profile:
# LLM_COMPATIBLE_API_SOURCE=openai
# LLM_COMPATIBLE_API_BASE_URL=https://your-upstream.example.com/v1
# LLM_COMPATIBLE_API_API_KEY=sk-your-key

# Usually required when serving a saved interactive profile:
# OPENAI_API_KEY=sk-your-key
# ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_AUTH_TOKEN=your-bearer-token

# In Docker, bind to all interfaces so published ports are reachable on the host.
# LLM_COMPATIBLE_API_HOST=0.0.0.0
# LLM_COMPATIBLE_API_PORT=10531

# Optional
# LLM_COMPATIBLE_API_MODELS=gpt-5.4,gpt-5.3-codex
# LLM_COMPATIBLE_API_DEFAULT_MODEL=gpt-5.4
# LLM_COMPATIBLE_API_HEADERS=x-vendor-flag=enabled,x-another-header=value
