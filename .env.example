# Copy this file to .env only if you want environment variables to override
# the saved Docker Compose profile created by `docker compose run --rm llm-compatible-api init`.
#
# Direct-start env is used when source and API key are set.
# Base URL is optional and defaults to official OpenAI/Anthropic endpoints.
# Otherwise env is ignored and the saved interactive profile can be used.
# LLM_COMPATIBLE_API_SOURCE=openai
# LLM_COMPATIBLE_API_API_KEY=sk-your-key
# Optional for third-party or non-default upstreams:
# LLM_COMPATIBLE_API_BASE_URL=https://your-upstream.example.com/v1

# Optional for OpenAI-compatible upstreams. Defaults to chat.
# LLM_COMPATIBLE_API_UPSTREAM_API_FORMAT=chat
# LLM_COMPATIBLE_API_UPSTREAM_API_FORMAT=responses

# In Docker, bind to all interfaces so published ports are reachable on the host.
# LLM_COMPATIBLE_API_HOST=0.0.0.0
# LLM_COMPATIBLE_API_PORT=10531

# Optional
# LLM_COMPATIBLE_API_MODELS=gpt-5.4,gpt-5.3-codex
# LLM_COMPATIBLE_API_DEFAULT_MODEL=gpt-5.4
# Require local proxy clients to send Authorization: Bearer <key>.
# LLM_COMPATIBLE_API_EXPOSED_API_KEY=sk-client-key
# Or use each client Bearer key as the upstream source API key.
# LLM_COMPATIBLE_API_CLIENT_API_KEY_MODE=bypass
# LLM_COMPATIBLE_API_HEADERS=x-vendor-flag=enabled,x-another-header=value

# Optional Docker Compose host config dirs.
# Defaults use HOME, falling back to USERPROFILE on Windows.
# LLM_COMPATIBLE_API_CODEX_DIR=${HOME}/.codex
# LLM_COMPATIBLE_API_CLAUDE_DIR=${HOME}/.claude
