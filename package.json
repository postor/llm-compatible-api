{
	"name": "llm-compatible-api-monorepo",
	"private": true,
	"description": "Bridge one active upstream source into local OpenAI and Anthropic compatible endpoints.",
	"packageManager": "pnpm@10.0.0",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"dev": "tsx packages/openai-oauth/src/cli.ts",
		"dev:all": "turbo run dev",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test",
		"format-and-lint": "biome check .",
		"format-and-lint:fix": "biome check . --write"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.10",
		"tsup": "^8.5.0",
		"turbo": "^2.6.3",
		"tsx": "^4.20.6",
		"typescript": "5.9.2"
	},
	"author": "EvanZhouDev",
	"license": "AGPL-3.0-only",
	"bugs": {
		"url": "https://github.com/postor/llm-compatible-api/issues"
	},
	"homepage": "https://github.com/postor/llm-compatible-api#readme"
}
